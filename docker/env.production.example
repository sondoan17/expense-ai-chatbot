# ================================
# Production Environment Variables
# ================================
# Copy this file to .env and fill in the values

# --------------------------------
# Database (Your external server)
# --------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@YOUR_DB_HOST:5432/expense?schema=public

# --------------------------------
# API Configuration
# --------------------------------
NODE_ENV=production
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_long
JWT_EXPIRES_IN=7d
PORT=4000
APP_TIMEZONE=Asia/Ho_Chi_Minh

# AI Service
PROVIDER_URL=https://ai.mimichatbot.fun/v1
PROVIDER_API_KEY=your_provider_api_key
AI_MODEL=cx/gpt-5.5
AGENT_QUERY_TEMPLATE_REPLIES=true

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key

# --------------------------------
# Frontend Configuration
# --------------------------------
VITE_API_BASE_URL=https://mimichatbot.fun/api

# CORS - allowed origins (comma separated)
WEB_ORIGIN=https://mimichatbot.fun,https://www.mimichatbot.fun

# --------------------------------
# Domain Configuration
# --------------------------------
DOMAIN=mimichatbot.fun
